{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": "./",
    "paths": {
      "@web/*": ["src/web/*"],
      "@api/*": ["src/api/*"],
      "@mobile/*": ["src/mobile/*"],
      "@core/*": ["src/core/*"],
      "@shared/*": ["src/shared/*"],
      "@config/*": ["config/*"]
    },
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*", "tests/**/*", "config/**/*"],
  "exclude": ["node_modules", "dist", "reports"]
}
